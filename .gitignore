# ========== セキュリティ - 絶対にアップロードしないファイル ==========
.env
.env.*
*.env
config.secret.*
*_credentials.*
*.key
*.pem
secrets.json
secrets.yaml
secrets.yml

# ========== 大容量データファイル（オプション） ==========
# CSVやJSONはサイズが大きいためデフォルトで除外
# アップロードしたい場合は該当行をコメントアウト
# fishing_condition_db.csv
# fishing_muroto_v2_filtered.csv
# muroto_offshore_current_all.csv
# analysis_result.json

# ========== Pythonキャッシュ ==========
__pycache__/
*.py[cod]
*$py.class
*.pyc
.pytest_cache/

# ========== システムファイル ==========
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.bak
*.swp
*~

# ========== detect-secrets ==========
.secrets.baseline

# ========== Node.js（将来使う場合） ==========
node_modules/
npm-debug.log*
